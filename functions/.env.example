# ════════════════════════════════════════════════════════════════════════════════
# FRIMS — LOCAL DEVELOPMENT ENVIRONMENT TEMPLATE
# ════════════════════════════════════════════════════════════════════════════════
#
# ⚠️  THIS FILE IS FOR LOCAL DEVELOPMENT ONLY.
#     In production (Firebase Cloud Functions) ALL values come from
#     Firebase Secret Manager — never from a .env file.
#
# USAGE:
#   cp .env.example .env
#   # Fill in your local / dev-tier values, then:
#   npm run dev
#
# HOW TO ADD A SECRET FOR PRODUCTION:
#   firebase functions:secrets:set VARIABLE_NAME
#   (Firebase will prompt you to type the value securely)
#
# ════════════════════════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (use a dev/test cluster, not production)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/frims_dev?retryWrites=true&w=majority

# JWT signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_random_96_char_hex_string
JWT_EXPIRES_IN=7d

# Firebase project (your dev project, not production)
FIREBASE_PROJECT_ID=your-dev-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-dev-firebase-project-id.appspot.com

# Path to service account key JSON (downloaded from Firebase Console)
# This file is git-ignored — never commit it.
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# Gmail SMTP — use an App Password (see SETUP.md §5)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-dev-email@gmail.com
EMAIL_PASS=your_16_char_app_password

# Frontend origin (for CORS) — your local React dev server
FRONTEND_URL=http://localhost:3000

# Department authorization code for inspector self-registration.
# Inspectors must enter this code when registering.
# Share this code only with authorised fire department personnel.
# If left empty, inspector self-registration is disabled.
# Generate a strong code:  node -e "console.log(require('crypto').randomBytes(12).toString('hex').toUpperCase())"
INSPECTOR_INVITE_CODE=

# ════════════════════════════════════════════════════════════════════════════════
# FRIMS CLIENT — LOCAL DEVELOPMENT ENVIRONMENT TEMPLATE
# ════════════════════════════════════════════════════════════════════════════════
#
# ⚠️  THIS FILE IS FOR LOCAL DEVELOPMENT ONLY.
#     In production the React app is built by GitHub Actions, which injects
#     every REACT_APP_* value from GitHub Secrets at build time.
#     No .env file is read during the production build.
#
# USAGE:
#   cp .env.local.example .env.local
#   # Fill in your dev project values, then:
#   npm start
#
# HOW TO SET A VALUE FOR PRODUCTION:
#   GitHub repo → Settings → Secrets and variables → Actions
#   → "New repository secret" → enter the REACT_APP_* name and value.
#
# ════════════════════════════════════════════════════════════════════════════════

# Backend API base URL — for local dev this hits your Express server via CRA proxy
REACT_APP_API_URL=http://localhost:5000/api

# Socket.IO server URL — same as the Express server in local dev
REACT_APP_SOCKET_URL=http://localhost:5000

# ── Firebase Web SDK config ──────────────────────────────────────────────────
# All values from: Firebase Console → Project settings → Your apps → Web app
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-dev-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-dev-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-dev-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# VAPID key: Firebase Console → Project settings → Cloud Messaging → Web Push certificates
REACT_APP_FIREBASE_VAPID_KEY=your-vapid-key
